{
  "version": 4,
  "configurations": [
    {
      "name": "Mac",
      "compilerPath": "/usr/local/bin/g++-15",
      "intelliSenseMode": "macos-gcc-x64",
      "cStandard": "c17",
      "cppStandard": "c++17",
      "includePath": [
        "${workspaceFolder}/**"
      ],
      "browse": {
        "path": [
          "${workspaceFolder}"
        ],
        "limitSymbolsToIncludedHeaders": true
      }
    }
  ]
}