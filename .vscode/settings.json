{
  "files.associations": {
    "*.dbclient-js": "javascript",
    ".fantomasignore": "ignore",
    "*.cjson": "jsonc",
    "*.wxs": "javascript",
    "*.wxss": "css",
    "iostream": "cpp",
    "iosfwd": "cpp",
    "ostream": "cpp",
    "cmath": "cpp"
  },
  "python.useEnvironmentsExtension": true,
  "cph.language.cpp.Command": "/usr/local/bin/g++-15",
  "cph.language.cpp.Args": "-std=c++17 -O2 -Wall -Wextra",
  "code-runner.runInTerminal": true,
  "code-runner.executorMap": {
    "cpp": "cd $dir && /usr/local/bin/g++-15 -std=c++17 -O2 -Wall -Wextra -o $fileNameWithoutExt $fileName && ./$fileNameWithoutExt"
  },
  "python.languageServer": "None"
}